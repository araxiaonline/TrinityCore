################################################################################
#
#                    ARAXIA ONLINE CONFIGURATION
#
################################################################################
#
#    This configuration file contains all Araxia-specific settings.
#    It is loaded AFTER worldserver.conf, so settings here can override
#    worldserver.conf values if needed.
#
#    Place this file in the worldserver.conf.d/ directory (or etc/ folder)
#    to have it automatically loaded by the worldserver.
#
################################################################################

###############################################################################
#
#  ARAXIA EVENT BUS (ZEROMQ)
#
#    Araxia.EventBus.PublishEndpoint
#        ZeroMQ endpoint for publishing server events.
#        External subscribers connect to this endpoint to receive events.
#        Default: "tcp://*:5555"
#
#    Araxia.EventBus.SubscribeEndpoint
#        ZeroMQ endpoint for receiving external commands.
#        The server connects to this endpoint to receive commands.
#        Default: "tcp://127.0.0.1:5556"
#
#    Araxia.EventBus.EnableSpawnEvents
#        Enable publishing of creature spawn/despawn events.
#        Topics: world.spawn.*, dungeon.spawn.*, raid.spawn.*, bg.spawn.*
#        Default: 1 (enabled)
#
#    Araxia.EventBus.EnableEncounterEvents
#        Enable publishing of encounter events (boss fights).
#        Topics: *.encounter.start, *.encounter.end, *.encounter.spell_cast
#        Default: 1 (enabled)
#
#    Araxia.EventBus.EnablePlayerEvents
#        Enable publishing of player events (login, logout, death).
#        Topics: *.player.login, *.player.logout, *.player.death
#        Default: 1 (enabled)
#
###############################################################################

Araxia.EventBus.PublishEndpoint = "tcp://*:5555"
Araxia.EventBus.SubscribeEndpoint = "tcp://127.0.0.1:5556"
Araxia.EventBus.EnableSpawnEvents = 1
Araxia.EventBus.EnableEncounterEvents = 1
Araxia.EventBus.EnablePlayerEvents = 1

###############################################################################
#
#  ARAXIA MCP SERVER
#
#    Araxia.MCP.Enable
#        Enable the Model Context Protocol (MCP) server for AI integration.
#        Default: 1 (enabled)
#
#    Araxia.MCP.StdioMode
#        Run MCP server in stdio mode (for direct process communication).
#        When disabled, uses HTTP transport.
#        Default: 1 (stdio mode)
#
###############################################################################

Araxia.MCP.Enable = 1
Araxia.MCP.StdioMode = 1

###############################################################################
#
#  ARAXIA ELUNA EXTENSIONS
#
#    Araxia.Eluna.EnableSharedData
#        Enable ElunaSharedData for Lua<->C++ communication bridge.
#        Used by AMS (Addon Messaging System) and ZMQ bridge.
#        Default: 1 (enabled)
#
###############################################################################

Araxia.Eluna.EnableSharedData = 1

